{
	"name": "@kolisachint/hooteams-webui",
	"version": "0.1.26",
	"description": "hooteams web UI: live team mission control (SSE stream view + DAG replay), served by `hooteams start`",
	"type": "module",
	"main": "./serve.ts",
	"types": "./serve.ts",
	"exports": {
		".": "./serve.ts"
	},
	"files": [
		"dist",
		"serve.ts"
	],
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"check": "biome check --write --error-on-warnings . && tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.5",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"zustand": "^5.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@tailwindcss/vite": "^4.1.10",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@vitejs/plugin-react": "^4.5.0",
		"tailwindcss": "^4.1.10",
		"typescript": "^5.9.2",
		"vite": "^6.3.5"
	},
	"author": "Sachin Koli",
	"license": "MIT"
}
