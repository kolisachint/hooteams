{
	"name": "hooteams-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"test": "bun test",
		"check": "tsc --noEmit",
		"version:patch": "bun scripts/bump-versions.mjs patch",
		"version:minor": "bun scripts/bump-versions.mjs minor",
		"version:major": "bun scripts/bump-versions.mjs major",
		"release:patch": "bun scripts/release.mjs patch",
		"release:minor": "bun scripts/release.mjs minor",
		"release:major": "bun scripts/release.mjs major",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/bun": "^1.3.0",
		"husky": "^9.1.7",
		"typescript": "^5.9.2"
	},
	"engines": {
		"bun": ">=1.2.0"
	}
}
